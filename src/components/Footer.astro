---
import type { HTMLAttributes } from "astro/types";
import Socials from "./Socials.astro";

const currentYear = new Date().getFullYear();

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div class="border-t border-border py-8">
    <nav
      class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-xs tracking-wide text-foreground-muted"
    >
      <a href="/about" class="transition hover:text-accent">About</a>
      <a href="/tools" class="transition hover:text-accent">ツール辞書</a>
      <a href="/shop" class="transition hover:text-accent">ショップ</a>
      <a href="/disclosure" class="transition hover:text-accent"
        >広告・アフィリエイト表記</a
      >
      <a href="/privacy" class="transition hover:text-accent"
        >プライバシーポリシー</a
      >
    </nav>
    <p class="mt-4 text-center text-[11px] leading-relaxed text-foreground-muted">
      当サイトは第三者配信のアフィリエイトプログラムを利用しています。詳細は<a
        href="/disclosure"
        class="border-b border-foreground-muted/40 transition hover:border-accent hover:text-accent"
        >広告・アフィリエイト表記</a
      >をご覧ください。
    </p>
    <div
      class="mt-6 flex flex-col items-center justify-between gap-3 sm:flex-row-reverse"
    >
      <Socials />
      <div
        class="flex flex-col items-center whitespace-nowrap text-xs sm:flex-row"
      >
        <span>Copyright &#169; {currentYear}</span>
        <span class="hidden sm:inline">&nbsp;|&nbsp;</span>
        <span>All rights reserved.</span>
      </div>
    </div>
  </div>
</footer>
