---
// ai-maker-lab CalloutIcon
// 使い方: <CalloutIcon variant="tip" /> または <CalloutIcon variant="warn" size="lg" />
// variant: tip | warn | tool | cost | keyboard | clock | medal1 | medal2 | medal3 | trophy
//          | vibe | aitool | hosting | aico | aiside | domain | individual | code | read
// size:    sm (h-4 w-4) | md (h-6 w-6, default) | lg (h-20 w-20) | xl (h-24 w-24 sm:h-32 sm:w-32)
interface Props {
  variant:
    | "tip"
    | "warn"
    | "tool"
    | "cost"
    | "keyboard"
    | "clock"
    | "medal1"
    | "medal2"
    | "medal3"
    | "trophy"
    | "vibe"
    | "aitool"
    | "hosting"
    | "aico"
    | "aiside"
    | "domain"
    | "individual"
    | "code"
    | "read";
  size?: "sm" | "md" | "lg" | "xl";
  alt?: string;
  class?: string;
}
const { variant, size = "md", alt, class: extraClass = "" } = Astro.props as Props;

// インライン SVG / 画像どちらでも対応できるよう、type を含めて管理
type IconDef = { kind: "img"; src: string; defaultAlt: string } | { kind: "svg"; svg: string; defaultAlt: string };

const SVG_BULB = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>';
const SVG_WARN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';
const SVG_TOOL = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>';
const SVG_COIN = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v12M8 10h6.5a2.5 2.5 0 0 1 0 5H8"/></svg>';
const SVG_KEYBOARD = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M6 9h.01M10 9h.01M14 9h.01M18 9h.01M6 13h.01M10 13h.01M14 13h.01M18 13h.01M8 17h8"/></svg>';
const SVG_CLOCK = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>';

const MAP: Record<Props["variant"], IconDef> = {
  tip:        { kind: "svg", svg: SVG_BULB,     defaultAlt: "ヒント" },
  warn:       { kind: "svg", svg: SVG_WARN,     defaultAlt: "注意" },
  tool:       { kind: "svg", svg: SVG_TOOL,     defaultAlt: "編集部メモ" },
  cost:       { kind: "svg", svg: SVG_COIN,     defaultAlt: "コスト" },
  keyboard:   { kind: "svg", svg: SVG_KEYBOARD, defaultAlt: "コマンド" },
  clock:      { kind: "svg", svg: SVG_CLOCK,    defaultAlt: "時計" },
  medal1:     { kind: "img", src: "/icons/medal-1.png", defaultAlt: "1位" },
  medal2:     { kind: "img", src: "/icons/medal-2.png", defaultAlt: "2位" },
  medal3:     { kind: "img", src: "/icons/medal-3.png", defaultAlt: "3位" },
  trophy:     { kind: "img", src: "/icons/trophy-ai.png", defaultAlt: "トロフィー" },
  vibe:       { kind: "img", src: "/icons/vibe-coding.png", defaultAlt: "Vibe Coding" },
  aitool:     { kind: "img", src: "/icons/ai-tool.png", defaultAlt: "AIツール" },
  hosting:    { kind: "img", src: "/icons/hosting.png", defaultAlt: "ホスティング" },
  aico:       { kind: "img", src: "/icons/ai-company.png", defaultAlt: "AI会社" },
  aiside:     { kind: "img", src: "/icons/ai-side-business.png", defaultAlt: "AI副業" },
  domain:     { kind: "img", src: "/icons/domain.png", defaultAlt: "ドメイン" },
  individual: { kind: "img", src: "/icons/individual-dev.png", defaultAlt: "個人開発" },
  code:       { kind: "img", src: "/icons/code-block.png", defaultAlt: "コード" },
  read:       { kind: "img", src: "/icons/read-time.png", defaultAlt: "リード" },
};

const def = MAP[variant];
const altText = alt ?? def.defaultAlt;

const SIZE_CLASS: Record<NonNullable<Props["size"]>, { cls: string; w: number; h: number }> = {
  sm: { cls: "inline-block h-4 w-4 align-middle", w: 16, h: 16 },
  md: { cls: "inline-block h-6 w-6 align-middle", w: 24, h: 24 },
  lg: { cls: "h-20 w-20 object-contain drop-shadow-md", w: 80, h: 80 },
  xl: { cls: "h-24 w-24 sm:h-32 sm:w-32 object-contain drop-shadow-md", w: 128, h: 128 },
};
const { cls, w, h } = SIZE_CLASS[size];
const isHidden = !alt && size !== "lg" && size !== "xl";
---

{def.kind === "img" && (
  <img
    src={def.src}
    alt={isHidden ? "" : altText}
    aria-hidden={isHidden ? "true" : undefined}
    class={`${cls} ${extraClass}`}
    width={w}
    height={h}
    loading="lazy"
  />
)}
{def.kind === "svg" && (
  <span
    class={`${cls} ${extraClass} inline-flex items-center justify-center`}
    aria-hidden={isHidden ? "true" : undefined}
    role={isHidden ? undefined : "img"}
    aria-label={isHidden ? undefined : altText}
    set:html={def.svg}
  />
)}
