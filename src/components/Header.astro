---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());
  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const navLinks = [
  { href: "/posts", label: "記事" },
  { href: "/tags", label: "ツール比較" },
  { href: "/about", label: "About" },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="sticky top-0 z-40 border-b border-border bg-background/85 backdrop-blur-md supports-[backdrop-filter]:bg-background/65"
>
  <div
    class="site-layout flex h-14 items-center justify-between gap-2 sm:h-16"
  >
    <!-- Brand -->
    <a
      href="/"
      class="group flex items-center gap-2 text-base font-bold tracking-tight sm:text-lg"
    >
      <span
        class="grid size-7 place-items-center rounded-md bg-gradient-to-br from-accent to-secondary font-extrabold text-accent-fg shadow-sm sm:size-8"
        aria-hidden="true"
      >
        ⌘
      </span>
      <span class="hidden sm:inline">{SITE.title}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex md:items-center md:gap-1">
      {
        navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-1.5 text-sm font-medium transition",
              isActive(link.href)
                ? "bg-foreground/5 text-foreground"
                : "text-foreground/65 hover:bg-foreground/5 hover:text-foreground",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-1 sm:gap-2">
      <LinkButton
        href="/search"
        class="hidden size-9 items-center justify-center rounded-md text-foreground/65 transition hover:bg-foreground/5 hover:text-foreground sm:flex"
        title="Search"
        aria-label="search"
      >
        <IconSearch class="size-4" />
      </LinkButton>

      {
        SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="relative hidden size-9 items-center justify-center rounded-md text-foreground/65 transition hover:bg-foreground/5 hover:text-foreground sm:flex"
            title="ライト / ダーク切替"
            aria-label="auto"
            aria-live="polite"
          >
            <IconMoon class="absolute size-4 scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
            <IconSunHigh class="absolute size-4 scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
          </button>
        )
      }

      <a
        href="/diagnose"
        class="group inline-flex items-center gap-1.5 rounded-md bg-accent px-3 py-1.5 text-sm font-bold text-accent-fg shadow-sm shadow-accent/30 transition hover:scale-[1.02] hover:shadow-md hover:shadow-accent/40"
      >
        <span class="hidden sm:inline">AI診断</span>
        <span class="sm:hidden">診断</span>
        <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>

      <button
        id="menu-btn"
        class="ml-0.5 inline-flex size-9 items-center justify-center rounded-md text-foreground/65 transition hover:bg-foreground/5 hover:text-foreground md:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <IconX id="close-icon" class="hidden size-4" />
        <IconMenuDeep id="menu-icon" class="size-4" />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-border bg-background md:hidden"
  >
    <div class="site-layout flex flex-col py-2">
      {
        navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              "rounded-md px-3 py-2.5 text-sm font-medium transition",
              isActive(link.href)
                ? "bg-foreground/5 text-foreground"
                : "text-foreground/70 hover:bg-foreground/5 hover:text-foreground",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/search"
        class="rounded-md px-3 py-2.5 text-sm font-medium text-foreground/70 hover:bg-foreground/5 hover:text-foreground"
      >
        検索
      </a>
    </div>
  </nav>
</header>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";
      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");
      menuItems.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>
