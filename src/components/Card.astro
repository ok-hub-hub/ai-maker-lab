---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, featured, tags, ...props } = data;
const href = getPath(id, filePath);
---

<li class="group bg-background transition hover:bg-foreground/[0.012]">
  <a href={href} class="flex h-full flex-col gap-3 p-8 sm:p-10">
    <div class="flex items-center gap-3 text-[10px] tracking-[0.18em] text-foreground-muted uppercase">
      {
        featured && (
          <span class="font-medium text-accent">— Featured</span>
        )
      }
      {
        tags?.slice(0, 2).map(tag => (
          <span>{tag}</span>
        ))
      }
    </div>

    <Heading
      class="font-serif text-2xl leading-snug text-foreground transition group-hover:text-accent sm:text-[28px]"
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>

    <p class="line-clamp-3 text-[15px] leading-[1.8] text-foreground-muted">{description}</p>

    <div class="mt-auto flex items-baseline justify-between pt-4">
      <span class="text-[11px] tracking-wide text-foreground-muted">
        <Datetime {...props} />
      </span>
      <span
        class="inline-flex items-center gap-1 text-xs tracking-wide text-foreground-muted transition group-hover:text-accent"
      >
        続きを読む
        <span class="transition-transform group-hover:translate-x-1">→</span>
      </span>
    </div>
  </a>
</li>
