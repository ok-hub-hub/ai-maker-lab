---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, featured, tags, ...props } = data;
const href = getPath(id, filePath);
---

<li class="group my-5">
  <a
    href={href}
    class="block rounded-xl border border-border bg-card-bg p-5 transition hover:-translate-y-0.5 hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5"
  >
    <div class="mb-2 flex flex-wrap items-center gap-2">
      {
        featured && (
          <span class="inline-flex items-center gap-1 rounded-md bg-accent px-2 py-0.5 text-[10px] font-bold text-accent-fg uppercase">
            ⭐ Featured
          </span>
        )
      }
      {
        tags?.slice(0, 3).map(tag => (
          <span class="rounded-md bg-foreground/[0.06] px-2 py-0.5 text-[10px] font-semibold tracking-wide text-foreground/70 uppercase">
            #{tag}
          </span>
        ))
      }
    </div>

    <Heading
      class="mb-2 text-xl font-bold leading-snug text-foreground transition group-hover:text-accent sm:text-2xl"
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>

    <div class="mb-2 text-xs text-foreground/50">
      <Datetime {...props} />
    </div>

    <p class="line-clamp-3 text-sm text-foreground/70">{description}</p>

    <div
      class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-accent opacity-0 transition group-hover:opacity-100"
    >
      続きを読む
      <span class="transition-transform group-hover:translate-x-1">→</span>
    </div>
  </a>
</li>
