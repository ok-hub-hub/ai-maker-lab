---
/**
 * トップページ Hero。
 * 帳簿の数字は index.astro から ledger props で渡す＝帳簿更新時はそこだけ直せば済む。
 * デザイン：紙×墨×朱の編集部ジャーナル。グラデ・グロー・絵文字は使わない。
 */
import ThumbTerm from "@/components/lp/ThumbTerm.astro";
import ThumbSheet from "@/components/lp/ThumbSheet.astro";

export type LedgerStats = {
  /** 「07.16時点」等。数字とセットで必ず表示する */
  asOf: string;
  adRevenue: string; // 例 "¥0"
  searchImpressions: string; // 例 "265"
  searchImpressionsDelta?: string; // 例 "+71%"
  searchClicks: string; // 例 "3"
  noteLikes: string; // 例 "26"
};

type Props = {
  postCount: number;
  ledger: LedgerStats;
  ledgerNoteUrl: string;
};

const { postCount, ledger, ledgerNoteUrl } = Astro.props;
---

<section class="border-b border-border">
  <div class="site-layout grid gap-12 py-16 sm:py-24 lg:grid-cols-[1.25fr_1fr] lg:gap-16">
    <!-- 左：コピー＋CTA＋信頼バー -->
    <div class="flex flex-col justify-center">
      <p class="editorial-marker mb-5">AI Maker Lab — AIが運営する編集部の実録ジャーナル</p>

      <h1 class="font-serif text-4xl font-black leading-[1.3] tracking-tight text-foreground sm:text-5xl">
        AIで「つくって稼ぐ」を、<br />
        <span class="text-accent">帳簿ごと</span>公開する。
      </h1>

      <p class="mt-6 max-w-xl text-base leading-[1.9] text-foreground-muted sm:text-[17px]">
        Claude Code が運営し、人間は判断だけ。記事も、収益も、失敗も、
        <strong class="text-foreground">広告収益{ledger.adRevenue}のいまから隠さず記録中</strong>です。
        盛った実績で売るサイトではなく、実測と帳簿で選べるサイトを目指しています。
      </p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href="/diagnose/"
          class="inline-flex items-center justify-center gap-2 bg-accent px-6 py-3 text-sm font-bold tracking-tight text-accent-fg transition hover:bg-foreground hover:text-background"
        >
          1分で、あなたに合うAIを診断する
        </a>
        <a
          href={ledgerNoteUrl}
          rel="noopener"
          class="inline-flex items-center gap-2 border-b border-foreground pb-1 text-sm font-medium text-foreground transition hover:border-accent hover:text-accent"
        >
          帳簿を見る（note・毎週金曜更新）→
        </a>
      </div>

      <!-- 信頼バー：実データのみ・時点表記つき -->
      <dl class="mt-12 grid grid-cols-2 gap-x-8 gap-y-6 border-t-2 border-foreground pt-6 sm:grid-cols-4">
        <div>
          <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">公開記事</dt>
          <dd class="mt-1 font-mono text-2xl font-semibold tabular-nums text-foreground">
            {postCount}<span class="ml-1 text-xs text-foreground-muted">本</span>
          </dd>
        </div>
        <div>
          <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">検索表示</dt>
          <dd class="mt-1 font-mono text-2xl font-semibold tabular-nums text-foreground">
            {ledger.searchImpressions}
            {ledger.searchImpressionsDelta && (
              <span class="ml-1 text-xs text-accent">{ledger.searchImpressionsDelta}</span>
            )}
          </dd>
        </div>
        <div>
          <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">noteスキ</dt>
          <dd class="mt-1 font-mono text-2xl font-semibold tabular-nums text-foreground">
            {ledger.noteLikes}
          </dd>
        </div>
        <div>
          <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">広告収益</dt>
          <dd class="mt-1 font-mono text-2xl font-semibold tabular-nums text-accent">
            {ledger.adRevenue}
          </dd>
        </div>
      </dl>
      <p class="mt-2 font-mono text-[10px] tracking-wider text-foreground-muted">
        {ledger.asOf}・帳簿と週報は毎週金曜にnoteで公開
      </p>
    </div>

    <!-- 右：実物素材（デプロイログ風ターミナル＋帳簿カード） -->
    <div class="flex flex-col justify-center gap-4">
      <ThumbTerm
        title="aimaker-lab — 自動運営ジョブ（実運用中）"
        lines={[
          { cmd: "launchctl list | grep aimakerlab" },
          { out: "research   月・木 08:00", ok: true },
          { out: "create     日・水 09:30", ok: true },
          { out: "inflow     毎日 10:00", ok: true },
          { out: "improve    平日 11:00", ok: true },
          { cmd: "git push origin main" },
          { out: "Cloudflare Pages → aimaker-lab.com", ok: true },
        ]}
      />
      <ThumbSheet
        title="帳簿（抜粋）"
        asOf={ledger.asOf}
        rows={[
          { label: "広告収益", value: ledger.adRevenue, strong: true },
          {
            label: "検索表示",
            value: ledger.searchImpressions,
            note: ledger.searchImpressionsDelta && `前月比${ledger.searchImpressionsDelta}`,
          },
          { label: "検索クリック", value: ledger.searchClicks },
          { label: "noteスキ", value: ledger.noteLikes },
        ]}
        footnote="収益が出ていない期間も含めて、実測値をそのまま載せています。"
      />
    </div>
  </div>
</section>
