---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
---

<Layout
  title={`お問い合わせ | ${SITE.title}`}
  description={`${SITE.author} のお問い合わせページ。`}
>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout">
    <section id="contact" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">お問い合わせ</h1>
      <p class="text-sm opacity-70">最終更新：2026-05-24</p>

      <p class="mt-6">
        {SITE.author} に関するご質問・取材依頼・広告掲載のご相談・誤情報のご指摘等は、編集部公式 X アカウントの DM までご連絡ください。
      </p>

      <div class="my-6 rounded-2xl border px-6 py-6">
        <p class="text-sm font-semibold">お問い合わせ窓口</p>
        <p class="mt-2">
          <strong class="text-lg">X (Twitter) DM：<a href="https://x.com/aimakerlab" target="_blank" rel="noopener noreferrer">@aimakerlab</a></strong>
        </p>
        <p class="mt-2 text-xs opacity-70">
          AI Maker Lab 編集部 X アカウントの DM をご利用ください。Threads（<a href="https://www.threads.com/@aimaker_lab" target="_blank" rel="noopener noreferrer">@aimaker_lab</a>）からのご連絡も承ります。
        </p>
      </div>

      <h2>ご連絡の際のお願い</h2>
      <ul>
        <li>件名には【目的】を記載いただくと、優先的に対応いたします（例：【取材依頼】／【広告掲載相談】／【誤情報指摘】）</li>
        <li>返信は内容により <strong>2-7 営業日</strong> いただく場合があります</li>
        <li>営業に関するお問い合わせはご遠慮ください</li>
      </ul>

      <h2>こんなご相談を受け付けています</h2>
      <ul>
        <li><strong>取材依頼</strong>：編集部への取材・コメント依頼</li>
        <li><strong>広告掲載相談</strong>：成果報酬型広告（PR）の掲載に関するご相談</li>
        <li><strong>誤情報のご指摘</strong>：掲載内容の事実誤認・最新情報との相違に関するご指摘</li>
        <li><strong>AI ツールに関するご質問</strong>：本サイトで紹介している Vibe Coding・AI 動画・AI 音声等のツールの選び方等</li>
        <li><strong>その他</strong>：上記以外のお問い合わせ</li>
      </ul>

      <p class="mt-10 text-sm opacity-70">
        編集方針・編集体制の詳細は <a href="/editorial-team/">編集部紹介ページ</a> をご覧ください。
      </p>
    </section>
  </main>
  <Footer />
</Layout>
