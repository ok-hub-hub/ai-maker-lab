---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import { TOOLS } from "@/data/tools";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

const heroTools = TOOLS.filter(t => t.affiliateTier === "S").slice(0, 4);

const journals = [
  {
    label: "AI診断",
    href: "/diagnose",
    desc: "5問で、あなたに合うツールを3つ。",
    no: "01",
  },
  {
    label: "ツール比較",
    href: "/tags",
    desc: "24種類のAIを領域別に。",
    no: "02",
  },
  {
    label: "実体験レビュー",
    href: "/posts",
    desc: "個人開発者の検証記録。",
    no: "03",
  },
  {
    label: "収益化ガイド",
    href: "/tags/announcement",
    desc: "副業ロードマップ。",
    no: "04",
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <!-- ========== HERO ========== -->
    <section class="border-b border-border">
      <div class="site-layout grid gap-12 py-20 sm:py-28 lg:grid-cols-[1.3fr_1fr] lg:gap-20">
        <!-- 左：価値提案 -->
        <div class="flex flex-col justify-center">
          <div class="mb-8 flex items-center gap-3 text-[11px] tracking-[0.2em] text-foreground-muted uppercase">
            <span class="h-px w-8 bg-foreground-muted/40"></span>
            <span>An Editorial Guide · 2026</span>
          </div>

          <h1
            class="font-serif text-[44px] leading-[1.15] font-medium tracking-tight text-foreground sm:text-[56px] lg:text-[68px]"
          >
            個人が、<br />
            <span class="italic text-accent">AIで</span>つくる、<br />
            稼ぐ、ための<br />
            実体験ジャーナル。
          </h1>

          <p class="mt-8 max-w-xl text-base leading-[1.85] text-foreground-muted sm:text-[17px]">
            Vibe Coding、AI動画、AI音声、業務自動化。<br />
            一通り触った個人開発者が、料金・できること・<br />
            収益化の現実までを、正直に書きとめます。
          </p>

          <div class="mt-10 flex flex-col gap-5 sm:flex-row sm:items-center">
            <a
              href="/diagnose"
              class="group inline-flex items-center gap-3 self-start border-b border-foreground py-2 text-base font-medium tracking-tight text-foreground transition hover:border-accent hover:text-accent sm:self-auto"
            >
              1分でAI診断する
              <span
                class="inline-block transition-transform group-hover:translate-x-1.5"
                aria-hidden="true">→</span
              >
            </a>
            <a
              href="/posts"
              class="group inline-flex items-center gap-2 self-start text-sm font-medium tracking-tight text-foreground-muted transition hover:text-foreground sm:self-auto"
            >
              実体験レビューを読む
            </a>
          </div>

          <dl class="mt-14 grid grid-cols-3 gap-10 border-t border-border pt-8">
            <div>
              <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
                Tools
              </dt>
              <dd class="mt-2 font-serif text-3xl text-foreground sm:text-4xl">
                {TOOLS.length}
              </dd>
            </div>
            <div>
              <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
                Personas
              </dt>
              <dd class="mt-2 font-serif text-3xl text-foreground sm:text-4xl">
                3
              </dd>
            </div>
            <div>
              <dt class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
                Source
              </dt>
              <dd class="mt-2 font-serif text-xl text-foreground sm:text-2xl">
                実体験
              </dd>
            </div>
          </dl>
        </div>

        <!-- 右：エディトリアルなツール一覧 -->
        <aside class="lg:pt-2">
          <div class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
            Curated Tools
          </div>
          <h2 class="mt-2 font-serif text-2xl leading-snug text-foreground sm:text-3xl">
            月額継続報酬の<br />
            主力ツール
          </h2>

          <ol class="mt-8 flex flex-col">
            {
              heroTools.map((tool, i) => (
                <li class={i === 0 ? "border-t border-border" : ""}>
                  <a
                    href={`/go/${tool.id}`}
                    target="_blank"
                    rel="noopener sponsored"
                    class="group flex items-baseline gap-6 border-b border-border py-5 transition hover:bg-foreground/[0.015]"
                  >
                    <span class="font-mono text-xs text-foreground-muted">
                      0{i + 1}
                    </span>
                    <div class="min-w-0 flex-1">
                      <div class="flex items-baseline justify-between gap-4">
                        <span class="font-serif text-lg font-medium text-foreground transition group-hover:text-accent">
                          {tool.name}
                        </span>
                        <span class="shrink-0 font-mono text-xs tabular-nums text-foreground-muted">
                          {tool.priceMin === 0
                            ? "Free"
                            : `$${tool.priceMin}`}
                        </span>
                      </div>
                      <p class="mt-1 line-clamp-1 text-sm text-foreground-muted">
                        {tool.description}
                      </p>
                    </div>
                    <span
                      class="shrink-0 text-foreground-muted opacity-0 transition group-hover:translate-x-0.5 group-hover:opacity-100"
                      aria-hidden="true">→</span
                    >
                  </a>
                </li>
              ))
            }
          </ol>

          <div class="mt-6 flex flex-col gap-3">
            <a
              href="/tools"
              class="group inline-flex items-center gap-2 text-xs tracking-wide text-foreground-muted transition hover:text-accent"
            >
              <span class="border-b border-foreground-muted/40 pb-0.5 group-hover:border-accent">
                26ツール辞書を領域別に見る
              </span>
              <span class="transition-transform group-hover:translate-x-0.5"
                >→</span>
            </a>
            <a
              href="/diagnose"
              class="group inline-flex items-center gap-2 text-xs tracking-wide text-foreground-muted transition hover:text-accent"
            >
              <span class="border-b border-foreground-muted/40 pb-0.5 group-hover:border-accent">
                あなたに合うツールを診断する
              </span>
              <span class="transition-transform group-hover:translate-x-0.5"
                >→</span>
            </a>
          </div>
        </aside>
      </div>
    </section>

    <!-- ========== ジャーナル（4セクション） ========== -->
    <section class="border-b border-border">
      <div class="site-layout py-16 sm:py-20">
        <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
          <div>
            <div class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
              Sections
            </div>
            <h2 class="mt-1 font-serif text-3xl text-foreground sm:text-4xl">
              どこから読みますか
            </h2>
          </div>
          <p class="text-sm text-foreground-muted">3層ペルソナで設計しました</p>
        </div>

        <div class="grid divide-y divide-border border-t border-border lg:grid-cols-2 lg:divide-x lg:divide-y-0 lg:[&>a:nth-child(3)]:border-t lg:[&>a:nth-child(4)]:border-t lg:[&>a:nth-child(n+3)]:border-border">
          {
            journals.map(j => (
              <a
                href={j.href}
                class="group flex items-baseline gap-6 py-7 pr-2 transition hover:bg-foreground/[0.015]"
              >
                <span class="font-mono text-xs text-foreground-muted">
                  {j.no}
                </span>
                <div class="flex-1">
                  <div class="font-serif text-xl text-foreground transition group-hover:text-accent sm:text-2xl">
                    {j.label}
                  </div>
                  <p class="mt-1 text-sm text-foreground-muted">{j.desc}</p>
                </div>
                <span class="text-foreground-muted transition group-hover:translate-x-1 group-hover:text-accent">
                  →
                </span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ========== Featured ========== -->
    {
      featuredPosts.length > 0 && (
        <section
          class:list={[
            "py-16 sm:py-20",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <div class="site-layout">
            <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
              <div>
                <div class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
                  Editor's Picks
                </div>
                <h2 class="mt-1 font-serif text-3xl text-foreground sm:text-4xl">
                  おすすめ記事
                </h2>
              </div>
              <a
                href="/posts"
                class="border-b border-foreground-muted/40 pb-0.5 text-xs tracking-wide text-foreground-muted transition hover:border-accent hover:text-accent"
              >
                すべての記事 →
              </a>
            </div>
            <ul class="grid gap-px bg-border sm:grid-cols-2">
              {featuredPosts.map(data => (
                <Card variant="h3" {...data} />
              ))}
            </ul>
          </div>
        </section>
      )
    }

    <!-- ========== Recent ========== -->
    {
      recentPosts.length > 0 && (
        <section class="py-16 sm:py-20">
          <div class="site-layout">
            <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
              <div>
                <div class="text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
                  Latest
                </div>
                <h2 class="mt-1 font-serif text-3xl text-foreground sm:text-4xl">
                  最新レビュー
                </h2>
              </div>
              <a
                href="/posts"
                class="border-b border-foreground-muted/40 pb-0.5 text-xs tracking-wide text-foreground-muted transition hover:border-accent hover:text-accent"
              >
                すべての記事 →
              </a>
            </div>
            <ul class="grid gap-px bg-border sm:grid-cols-2">
              {recentPosts.map(
                (data, index) =>
                  index < SITE.postPerIndex && <Card variant="h3" {...data} />
              )}
            </ul>
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
