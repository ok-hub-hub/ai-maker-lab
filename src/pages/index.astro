---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";
import { TOOLS } from "@/data/tools";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);

// ヒーロー右側の人気ツールミニ表（アフィリTier S を優先、最大3つ）
const heroTools = TOOLS.filter(t => t.affiliateTier === "S").slice(0, 3);

// カテゴリリンク（収益サイト感の導線）
const categories = [
  {
    label: "AI診断",
    href: "/diagnose",
    desc: "1分でツール3つを提案",
    accent: true,
  },
  { label: "ツール比較", href: "/tags", desc: "24ツールから探す" },
  { label: "実体験レビュー", href: "/posts", desc: "個人開発者の検証記録" },
  { label: "収益化ガイド", href: "/tags/announcement", desc: "副業ロードマップ" },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <!-- ========== HERO ========== -->
    <section class="relative overflow-hidden border-b border-border">
      <!-- 背景グラデーション -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 -z-10"
        style="background:
          radial-gradient(800px 400px at 10% 10%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%),
          radial-gradient(700px 350px at 90% 30%, color-mix(in srgb, var(--secondary) 12%, transparent), transparent 60%);"
      >
      </div>
      <!-- 細かいグリッド線 -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 -z-10 opacity-[0.04]"
        style="background-image:
          linear-gradient(to right, currentColor 1px, transparent 1px),
          linear-gradient(to bottom, currentColor 1px, transparent 1px);
          background-size: 48px 48px;"
      >
      </div>

      <div class="site-layout grid gap-10 py-14 sm:py-20 lg:grid-cols-[1.15fr_1fr] lg:gap-16">
        <!-- 左：価値提案 -->
        <div class="flex flex-col justify-center">
          <span
            class="mb-5 inline-flex w-fit items-center gap-1.5 rounded-full border border-accent/30 bg-accent/10 px-3 py-1 text-[11px] font-bold tracking-wider text-accent uppercase"
          >
            <span class="size-1.5 animate-pulse rounded-full bg-accent"></span>
            2026年最新・{TOOLS.length}ツール比較
          </span>

          <h1
            class="text-4xl leading-[1.05] font-extrabold tracking-tight sm:text-5xl lg:text-6xl"
          >
            個人が、<wbr /><span
              class="bg-gradient-to-r from-accent via-orange-400 to-secondary bg-clip-text text-transparent"
              >AIで稼ぐ</span
            >ための<br class="hidden sm:block" />
            実体験ベース比較サイト。
          </h1>

          <p class="mt-6 max-w-xl text-base text-foreground/65 sm:text-lg">
            Vibe Coding（v0 / Lovable / Bolt）、AI動画（Synthesia / HeyGen）、
            AI音声（ElevenLabs）、業務自動化（n8n / GetResponse）。
            一通り触った個人開発者が、料金・できること・収益化の現実まで正直に書きます。
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="/diagnose"
              class="group inline-flex items-center justify-center gap-2 rounded-lg bg-accent px-5 py-3.5 text-base font-bold text-accent-fg shadow-lg shadow-accent/25 transition hover:scale-[1.02] hover:shadow-xl hover:shadow-accent/35"
            >
              1分でAI診断する
              <span class="transition-transform group-hover:translate-x-1"
                >→</span
              >
            </a>
            <a
              href="/posts"
              class="inline-flex items-center justify-center gap-2 rounded-lg border border-border px-5 py-3.5 text-base font-semibold text-foreground/80 transition hover:border-accent/60 hover:text-foreground"
            >
              実体験レビューを読む
            </a>
          </div>

          <!-- スタッツ -->
          <dl class="mt-10 grid max-w-md grid-cols-3 gap-6 text-left">
            <div>
              <dt class="text-xs font-medium tracking-wide text-foreground/50 uppercase">
                比較ツール
              </dt>
              <dd class="mt-1 text-2xl font-extrabold tracking-tight sm:text-3xl">
                {TOOLS.length}
                <span class="text-sm font-semibold text-foreground/50">種</span>
              </dd>
            </div>
            <div>
              <dt class="text-xs font-medium tracking-wide text-foreground/50 uppercase">
                読者層
              </dt>
              <dd class="mt-1 text-2xl font-extrabold tracking-tight sm:text-3xl">
                3
                <span class="text-sm font-semibold text-foreground/50">層</span>
              </dd>
            </div>
            <div>
              <dt class="text-xs font-medium tracking-wide text-foreground/50 uppercase">
                情報源
              </dt>
              <dd class="mt-1 text-2xl font-extrabold tracking-tight sm:text-3xl">
                実体験
              </dd>
            </div>
          </dl>
        </div>

        <!-- 右：人気ツール比較ミニ表 -->
        <aside class="relative">
          <div
            class="rounded-2xl border border-border bg-card-bg/95 p-5 shadow-xl shadow-black/[0.03] backdrop-blur sm:p-6"
          >
            <div class="mb-4 flex items-center justify-between">
              <h2 class="text-sm font-bold tracking-tight">
                <span class="text-accent">月額継続</span>アフィリ対応の主力ツール
              </h2>
              <span
                class="rounded-md bg-success/10 px-1.5 py-0.5 text-[10px] font-bold text-success"
              >
                Tier S
              </span>
            </div>

            <ol class="flex flex-col gap-3">
              {
                heroTools.map((tool, i) => (
                  <li>
                    <a
                      href={`/go/${tool.id}`}
                      target="_blank"
                      rel="noopener sponsored"
                      class="group flex items-start gap-3 rounded-lg border border-border bg-background/50 p-3 transition hover:border-accent/40 hover:bg-foreground/[0.02]"
                    >
                      <span class="grid size-7 shrink-0 place-items-center rounded-md bg-foreground/[0.06] text-xs font-bold text-foreground/70">
                        {i + 1}
                      </span>
                      <div class="min-w-0 flex-1">
                        <div class="flex items-baseline justify-between gap-2">
                          <span class="truncate text-sm font-bold">
                            {tool.name}
                          </span>
                          <span class="shrink-0 text-[10px] font-semibold text-foreground/55">
                            {tool.priceMin === 0
                              ? "Free〜"
                              : `$${tool.priceMin}〜`}
                          </span>
                        </div>
                        <p class="mt-0.5 line-clamp-2 text-xs text-foreground/55">
                          {tool.description}
                        </p>
                      </div>
                      <span
                        class="self-center text-foreground/30 transition group-hover:translate-x-0.5 group-hover:text-accent"
                      >
                        →
                      </span>
                    </a>
                  </li>
                ))
              }
            </ol>

            <a
              href="/diagnose"
              class="mt-4 flex items-center justify-center gap-1 rounded-lg border border-dashed border-border py-2.5 text-xs font-semibold text-foreground/65 transition hover:border-accent/40 hover:text-accent"
            >
              あなたに合うツールを診断する
              <span>→</span>
            </a>
          </div>
        </aside>
      </div>
    </section>

    <!-- ========== カテゴリ ========== -->
    <section class="site-layout border-b border-border py-12 sm:py-16">
      <div class="mb-6 flex items-baseline justify-between">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          どこから読む？
        </h2>
        <p class="text-xs text-foreground/55">3層ペルソナで設計</p>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          categories.map(cat => (
            <a
              href={cat.href}
              class:list={[
                "group relative flex flex-col gap-1 rounded-xl border p-5 transition",
                cat.accent
                  ? "border-accent/40 bg-gradient-to-br from-accent/5 via-transparent to-secondary/5 hover:border-accent/70"
                  : "border-border bg-card-bg hover:border-accent/40 hover:bg-card-bg/80",
              ]}
            >
              <span
                class:list={[
                  "text-sm font-bold tracking-tight",
                  cat.accent ? "text-accent" : "",
                ]}
              >
                {cat.label}
              </span>
              <span class="text-xs text-foreground/60">{cat.desc}</span>
              <span class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-foreground/50 transition group-hover:text-accent">
                ひらく
                <span class="transition-transform group-hover:translate-x-0.5">
                  →
                </span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ========== Featured ========== -->
    {
      featuredPosts.length > 0 && (
        <section
          class:list={[
            "site-layout py-12 sm:py-16",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <div class="mb-6 flex items-baseline justify-between">
            <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
              おすすめ記事
            </h2>
            <a
              href="/posts"
              class="text-xs font-semibold text-accent hover:underline"
            >
              すべての記事 →
            </a>
          </div>
          <ul class="grid gap-4 sm:grid-cols-2">
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <!-- ========== Recent ========== -->
    {
      recentPosts.length > 0 && (
        <section class="site-layout py-12 sm:py-16">
          <div class="mb-6 flex items-baseline justify-between">
            <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
              最新レビュー
            </h2>
            <a
              href="/posts"
              class="text-xs font-semibold text-accent hover:underline"
            >
              すべての記事 →
            </a>
          </div>
          <ul class="grid gap-4 sm:grid-cols-2">
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
