---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/lp/Hero.astro";
import RankItem from "@/components/lp/RankItem.astro";
import ThumbTerm from "@/components/lp/ThumbTerm.astro";
import ThumbSheet from "@/components/lp/ThumbSheet.astro";
import PersonaGrid from "@/components/lp/PersonaGrid.astro";
import ShopStrip from "@/components/lp/ShopStrip.astro";
import WeeklyCta from "@/components/lp/WeeklyCta.astro";
import Badge from "@/components/ui/Badge.astro";
import { TOOLS } from "@/data/tools";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const postCount = posts.length;

/**
 * 帳簿（実測値・捏造禁止）。毎週金曜のnote帳簿更新後、ここだけ直せばHeroに反映される。
 * 出典：GSC実測＋note帳簿（2026-07-16計測）。
 */
const LEDGER = {
  asOf: "07.16時点",
  adRevenue: "¥0",
  searchImpressions: "265",
  searchImpressionsDelta: "+71%",
  searchClicks: "3",
  noteLikes: "26",
};

const LEDGER_NOTE_URL = "https://note.com/aimakerlab/n/n9e06c0070235";
const NOTE_PROFILE_URL = "https://note.com/aimakerlab";

// 編集部ピック（実在記事・読了時間は本文から実算出）
function readMinutes(body: string): number {
  const jp = (body.match(/[　-鿿]/g) || []).length;
  const en = body.replace(/[　-鿿]/g, " ").split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(jp / 600 + en / 250));
}
function dateLabel(d: Date): string {
  const p = (n: number) => String(n).padStart(2, "0");
  return `${d.getFullYear()}.${p(d.getMonth() + 1)}.${p(d.getDate())}`;
}
function pick(slug: string) {
  const post = posts.find(p => p.id === slug);
  if (!post) throw new Error(`編集部ピックの記事が見つかりません: ${slug}`);
  return {
    href: `/posts/${slug}/`,
    title: post.data.title,
    dateLabel: dateLabel(post.data.modDatetime ?? post.data.pubDatetime),
    minutes: readMinutes(post.body ?? ""),
  };
}
const pick1 = pick("claude-code-ai-company-1month-2026");
const pick2 = pick("affiliate-2weeks-zero-to-video-pivot-2026");
const pick3 = pick("v0-vs-lovable-vs-bolt-2026");
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <!-- 1. Hero：コピー＋CTA2＋信頼バー＋ターミナル＋帳簿カード -->
    <Hero postCount={postCount} ledger={LEDGER} ledgerNoteUrl={LEDGER_NOTE_URL} />

    <!-- 2. 編集部ピック3本 -->
    <section class="border-b border-border">
      <div class="site-layout py-14 sm:py-20">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
          <div>
            <Badge withLine>Editor's Picks</Badge>
            <h2 class="mt-2 font-serif text-3xl font-black text-foreground sm:text-4xl">
              編集部ピック<span class="text-accent">3本</span>
            </h2>
          </div>
          <a
            href="/posts/"
            class="border-b border-foreground-muted/40 pb-0.5 text-xs tracking-wide text-foreground-muted transition hover:border-accent hover:text-accent"
          >
            すべての記事（{postCount}本）→
          </a>
        </div>
        <ol class="border-t-2 border-foreground">
          <RankItem
            rank={1}
            href={pick1.href}
            category="AI会社運営 / 実録"
            title={pick1.title}
            summary="このサイト自体を運営しているAI会社の1ヶ月記録。役割定義・相談処理・失敗事例・実績数字まで運営ログを全公開しています。"
            dateLabel={pick1.dateLabel}
            minutes={pick1.minutes}
          >
            <ThumbTerm
              title="ai-company — 4部門"
              lines={[
                { cmd: "claude -p 'CEOとして今日の判断を'" },
                { out: "CEO      判断・優先度づけ", ok: true },
                { out: "QA       レビュー・差し戻し", ok: true },
                { out: "事業開発  市場調査・商品設計", ok: true },
                { out: "技術検証  PoC・実装確認", ok: true },
              ]}
            />
          </RankItem>
          <RankItem
            rank={2}
            href={pick2.href}
            category="収益化 / 意思決定の実録"
            title={pick2.title}
            summary="3メディアを2週間で立ち上げて流入ゼロ。焦りと7回の旋回の末にピボットを決めるまでの、うまくいっていない期間の実況です。"
            dateLabel={pick2.dateLabel}
            minutes={pick2.minutes}
          >
            <ThumbSheet
              title="運営帳簿 Day14"
              asOf="2026.06.02"
              rows={[
                { label: "運営期間", value: "14日" },
                { label: "検索流入", value: "0" },
                { label: "意思決定", value: "ピボット", strong: true },
              ]}
            />
          </RankItem>
          <RankItem
            rank={3}
            href={pick3.href}
            category="ツール比較 / 実測"
            title={pick3.title}
            summary="Vibe Coding 3大ツールを料金・出力品質・日本語・デプロイで比較。副業・個人開発の用途別に「これを選べ」まで言い切ります。"
            dateLabel={pick3.dateLabel}
            minutes={pick3.minutes}
          >
            <ThumbSheet
              title="料金 実測表"
              asOf={pick3.dateLabel + "更新"}
              rows={[
                { label: "v0 by Vercel", value: "$30〜" },
                { label: "Lovable", value: "$25〜" },
                { label: "Bolt.new", value: "$20〜" },
              ]}
            />
          </RankItem>
        </ol>
      </div>
    </section>

    <!-- 3. 状況別入口3つ -->
    <section class="border-b border-border">
      <div class="site-layout py-14 sm:py-20">
        <div class="mb-8">
          <Badge withLine>Start Here</Badge>
          <h2 class="mt-2 font-serif text-3xl font-black text-foreground sm:text-4xl">
            いまの状況から、入口を選ぶ。
          </h2>
        </div>
        <PersonaGrid
          items={[
            {
              no: "01",
              need: "まず1本、動くものを作りたい",
              label: "SaaS MVP 1週間ロードマップを読む",
              href: "/posts/vibe-coding-saas-mvp-in-1week-2026/",
              desc: "v0 / Lovable / Cursor / Claude Code / Supabase を組み合わせ、Day1-7のタスク表つきで動くMVPまで進めます。",
            },
            {
              no: "02",
              need: "AIで副収入の道筋を知りたい",
              label: "AI副業ロードマップを読む",
              href: "/posts/ai-side-business-roadmap-2026/",
              desc: "月3万→10万→30万のレンジ別に、アフィリ／プロダクト販売／スキル販売の現実解と失敗パターンを整理しています。",
            },
            {
              no: "03",
              need: "どのツールを使うか、今日決めたい",
              label: "1分でAI診断する",
              href: "/diagnose/",
              desc: `用途・経験・予算の5問で、${TOOLS.length}ツールからあなたに合う3つに絞って提案します。`,
            },
          ]}
        />
      </div>
    </section>

    <!-- 4. 自社商品（実在3商品・価格は/shopと同期） -->
    <section class="border-b border-border">
      <div class="site-layout py-14 sm:py-20">
        <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
          <div>
            <Badge withLine>Shop</Badge>
            <h2 class="mt-2 font-serif text-3xl font-black text-foreground sm:text-4xl">
              実運用の仕組みを、そのまま商品に。
            </h2>
          </div>
          <a
            href="/shop/"
            class="border-b border-foreground-muted/40 pb-0.5 text-xs tracking-wide text-foreground-muted transition hover:border-accent hover:text-accent"
          >
            ショップを見る →
          </a>
        </div>
        <ShopStrip />
      </div>
    </section>

    <!-- 5. note週報CTA -->
    <section>
      <div class="site-layout py-14 sm:py-20">
        <WeeklyCta ledgerNoteUrl={LEDGER_NOTE_URL} noteProfileUrl={NOTE_PROFILE_URL} />
      </div>
    </section>
  </main>
  <!-- 6. フッター -->
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
