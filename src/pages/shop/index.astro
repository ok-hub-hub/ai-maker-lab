---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";

const title = "ショップ — AI Maker Lab の自社商品";
const description = "AI Maker Lab が制作・販売する個人開発者向けの実体験テンプレ集。Claude Code で動くAI会社運営テンプレ、Vibe Coding プロンプトパック など、すべて実運用ベース。";

type Product = {
  id: string;
  title: string;
  tagline: string;
  price: string;
  promoNote?: string;
  status: "live" | "coming-soon";
  url?: string;
  highlights: string[];
};

const products: Product[] = [
  {
    id: "ai-company-ops-template",
    title: "AI Company Ops Template",
    tagline: "Claude Code で動く 4 部門 AI会社 のテンプレ集 + 1ヶ月実運営ログ",
    price: "$39",
    promoNote: "プロモ価格（リリース後30日間）→ 通常 $49",
    status: "live",
    url: "https://okamuse.gumroad.com/l/ai-company-ops-template",
    highlights: [
      "役割定義書 5本（CEO / QA / 事業開発 / 技術検証 / 採用部）",
      "運用ファイルテンプレ 7本",
      "1ヶ月実運営ログ：相談ログ抜粋6件 / 失敗パターン4件 / 経営判断ログ4件",
      "ハンドブック 全8章",
      "リリース後6ヶ月間、月次アップデート無料配信",
    ],
  },
  {
    id: "vibe-coding-prompt-pack",
    title: "Vibe Coding プロンプトパック v1",
    tagline: "v0 / Lovable / Bolt / Cursor / Claude Code 用のプロンプト集",
    price: "$19-29（予定）",
    status: "coming-soon",
    highlights: [
      "個人開発者向け 50+ プロンプト",
      "日本語ネイティブ向けに最適化",
      "実運用検証済（AI Maker Lab で実証）",
      "ツール別の使い分けガイド付き",
    ],
  },
];
---

<Layout title={title} description={description}>
  <Header />
  <Breadcrumb />
  <main id="main-content" data-layout="shop-index">
    <!-- ========== HERO ========== -->
    <section class="border-b border-border">
      <div class="site-layout py-16 sm:py-20">
        <div
          class="mb-6 flex items-center gap-3 text-[11px] tracking-[0.2em] text-foreground-muted uppercase"
        >
          <span class="h-px w-8 bg-foreground-muted/40"></span>
          <span>Shop · Editorial Goods</span>
        </div>
        <h1
          class="max-w-3xl font-serif text-4xl leading-[1.15] text-foreground sm:text-5xl"
        >
          AI Maker Lab が実運用した テンプレと記録を、ここから。
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-relaxed text-foreground/75">
          OSS無料テンプレでは再現できない「実運営の判断・失敗・リカバリの記録」を、商品としてお届けします。すべて<a
            href="/tags/journal/"
            class="border-b border-foreground/30 hover:border-accent hover:text-accent">本サイトの連載</a
          >と並行して制作・販売しています。
        </p>
      </div>
    </section>

    <!-- ========== PRODUCTS ========== -->
    <section class="border-b border-border">
      <div class="site-layout py-12 sm:py-16">
        <div
          class="mb-8 flex items-center gap-3 text-[11px] tracking-[0.2em] text-foreground-muted uppercase"
        >
          <span class="h-px w-8 bg-foreground-muted/40"></span>
          <span>Products</span>
        </div>

        <div class="space-y-12">
          {
            products.map(product => (
              <article class="border-t border-border/60 pt-10 first:border-t-0 first:pt-0">
                <div class="grid gap-8 lg:grid-cols-[2fr_1fr]">
                  <div>
                    <div class="mb-3 flex items-center gap-3">
                      {product.status === "live" ? (
                        <span class="inline-flex items-center gap-2 rounded-sm bg-accent/10 px-2 py-0.5 text-[10px] tracking-[0.2em] text-accent uppercase">
                          <span class="size-1.5 rounded-full bg-accent" />
                          Live
                        </span>
                      ) : (
                        <span class="inline-flex items-center gap-2 rounded-sm bg-foreground-muted/10 px-2 py-0.5 text-[10px] tracking-[0.2em] text-foreground-muted uppercase">
                          Coming soon
                        </span>
                      )}
                      <span class="text-[11px] tracking-[0.18em] text-foreground-muted uppercase">
                        Item · {product.id}
                      </span>
                    </div>
                    <h2 class="mb-3 font-serif text-3xl leading-tight text-foreground">
                      {product.title}
                    </h2>
                    <p class="mb-6 text-base leading-relaxed text-foreground/75">
                      {product.tagline}
                    </p>
                    <ul class="space-y-2 text-sm leading-relaxed text-foreground/80">
                      {product.highlights.map(h => (
                        <li class="flex gap-3">
                          <span class="mt-1.5 size-1 shrink-0 rounded-full bg-accent" />
                          <span>{h}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <aside class="lg:border-l lg:border-border/60 lg:pl-8">
                    <div class="rounded-sm border border-border bg-background/40 p-6">
                      <div class="mb-2 text-[11px] tracking-[0.2em] text-foreground-muted uppercase">
                        Price
                      </div>
                      <div class="mb-1 font-serif text-3xl text-foreground">
                        {product.price}
                      </div>
                      {product.promoNote && (
                        <div class="mb-5 text-[12px] leading-snug text-foreground-muted">
                          {product.promoNote}
                        </div>
                      )}
                      {product.status === "live" && product.url ? (
                        <a
                          href={product.url}
                          target="_blank"
                          rel="noopener sponsored"
                          class="group inline-flex w-full items-center justify-center gap-2 border border-foreground bg-foreground px-4 py-2.5 text-sm font-medium tracking-tight text-background transition hover:border-accent hover:bg-accent"
                        >
                          <span>Gumroad で購入</span>
                          <span class="transition-transform group-hover:translate-x-0.5">→</span>
                        </a>
                      ) : (
                        <button
                          disabled
                          class="inline-flex w-full cursor-not-allowed items-center justify-center gap-2 border border-foreground-muted/40 px-4 py-2.5 text-sm font-medium tracking-tight text-foreground-muted"
                        >
                          準備中
                        </button>
                      )}
                    </div>
                  </aside>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ========== ABOUT THE SHOP ========== -->
    <section class="border-b border-border">
      <div class="site-layout py-12 sm:py-16">
        <div class="grid gap-10 lg:grid-cols-2">
          <div>
            <div
              class="mb-6 flex items-center gap-3 text-[11px] tracking-[0.2em] text-foreground-muted uppercase"
            >
              <span class="h-px w-8 bg-foreground-muted/40"></span>
              <span>About the shop</span>
            </div>
            <h2 class="mb-4 font-serif text-2xl leading-tight text-foreground">
              実体験ベース・OSS再現不可能
            </h2>
            <p class="text-sm leading-relaxed text-foreground/75">
              当ショップの商品は、すべて AI Maker Lab の運営者が <a
                href="/tags/journal/"
                class="border-b border-foreground/30 hover:border-accent hover:text-accent">個人ジャーナル連載</a
              >で実運用している内容を、商品として再構成したものです。OSS の無料テンプレでも基本機能は手に入りますが、「実運営でどんな失敗が起き、どう運用ルール化したか」の記録は再現できません。
            </p>
          </div>
          <div>
            <div
              class="mb-6 flex items-center gap-3 text-[11px] tracking-[0.2em] text-foreground-muted uppercase"
            >
              <span class="h-px w-8 bg-foreground-muted/40"></span>
              <span>Updates</span>
            </div>
            <h2 class="mb-4 font-serif text-2xl leading-tight text-foreground">
              月次アップデート保証
            </h2>
            <p class="text-sm leading-relaxed text-foreground/75">
              リリース後 6 ヶ月間、毎月の運営ログを既存購入者に無料配信します。AI業界の変化が早いため、商品も継続的にアップデートします。
            </p>
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
