---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Diagnose from "@/components/Diagnose";
---

<Layout
  title="AI診断 | あなたに合うAIツールを3つご提案します"
  description="無料・約30秒のAI診断。5つの質問に答えるだけで、あなたの目的（開発・ライティング・動画・キャリア）に合うAIツールを3つ提案し、実体験ベースの比較記事へ案内します。"
>
  <Header />
  <main id="main-content">
    <section class="border-b border-border">
      <div class="site-layout py-16 sm:py-24">
        <div class="mb-6 flex items-center gap-3 text-[11px] tracking-[0.2em] text-foreground-muted uppercase">
          <span class="h-px w-8 bg-foreground-muted/40"></span>
          <span>AI Tool Diagnosis · 5 Questions</span>
        </div>
        <h1
          class="font-serif text-4xl leading-[1.15] font-medium tracking-tight text-foreground sm:text-5xl lg:text-6xl"
        >
          1分で、あなたに合う<br />
          <span class="italic text-accent">AIツール</span>を3つご提案します。
        </h1>
        <p class="mt-6 max-w-2xl text-base leading-[1.8] text-foreground-muted sm:text-[17px]">
          5問の質問に答えるだけで、24種類のAIツールから「やりたいこと × 経験 × 予算」で
          最適な3つを抽出します。プログラミング経験は不要、所要時間は約1分です。
        </p>
      </div>
    </section>

    <section class="site-layout py-14 sm:py-20">
      <Diagnose client:load />
    </section>
  </main>
  <Footer />
</Layout>
