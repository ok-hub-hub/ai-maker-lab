---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import { getToolById } from "@/data/tools";
import AffiliateCta from "@/components/lp/AffiliateCta.astro";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  primaryGo,
  affiliateCta,
  review,
} = post.data;

// レビュー記事の Article+Review 構造化データ（rating は本文側にも可視表示する）
const reviewJsonLd = review
  ? {
      "@context": "https://schema.org",
      "@type": "Review",
      itemReviewed: {
        "@type": "SoftwareApplication",
        name: review.itemName,
        applicationCategory: "BusinessApplication",
        operatingSystem: "Web",
      },
      reviewRating: {
        "@type": "Rating",
        ratingValue: review.rating,
        bestRating: 5,
        worstRating: 1,
      },
      author: { "@type": "Organization", name: "AI Maker Lab", url: SITE.website },
      publisher: { "@type": "Organization", name: "AI Maker Lab", url: SITE.website },
      datePublished: pubDatetime.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
    }
  : null;

const { Content } = await render(post);

// 読了時間ざっくり算出（日本語: 600字/min、英語: 250語/min）
const _body = post.body ?? "";
const _jp = (_body.match(/[　-鿿]/g) || []).length;
const _en = _body.replace(/[　-鿿]/g, " ").split(/\s+/).filter(Boolean).length;
const readMinutes = Math.max(1, Math.round(_jp / 600 + _en / 250));

// アフィリ導線の検出：本文の最初の /go/<id> から主ツールを特定。
// PR表記（ステマ規制）とスマホ追従CTAの表示判定に使う。
// 冒頭の広告表記blockquote（> で始まる行）内のリンクは「主導線」ではないため検出から除外する。
// frontmatter の primaryGo があれば常にそれを優先（記事の文脈に合う導線を明示指定できる）。
const _goIds = [..._body.matchAll(/\/go\/([a-z0-9-]+)/g)].map(m => m[1]);
const _bodyNoQuote = _body
  .split("\n")
  .filter(l => !l.trimStart().startsWith(">"))
  .join("\n");
const _goIdsNoQuote = [..._bodyNoQuote.matchAll(/\/go\/([a-z0-9-]+)/g)].map(
  m => m[1]
);
const primaryGoId = primaryGo ?? _goIdsNoQuote[0] ?? _goIds[0];
const primaryTool = primaryGoId ? getToolById(primaryGoId) : undefined;
const hasAffiliate = _goIds.length > 0;
// CTA文言はツール種別で出し分け（転職エージェント=無料面談、それ以外=無料で試す）
const isAgentTool = primaryTool?.serviceType === "agent";
const ctaLabel = isAgentTool ? "無料面談を予約する »" : "無料で試してみる »";
const ctaSub = isAgentTool ? "求職者は無料・オンライン可" : "公式サイトで確認";

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${getPath(post.id, post.filePath)}index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | AI Maker Lab`,
  headline: title,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;

/* ========== 関連記事（タグ一致スコア上位3件） ========== */
const relatedPosts = posts
  .filter(p => p.id !== post.id)
  .map(p => ({
    post: p,
    score: p.data.tags.filter(tg => tags.includes(tg)).length,
  }))
  .filter(x => x.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(x => x.post);
---

<Layout {...layoutProps}>
  <Header />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-3 flex flex-wrap items-center gap-3 rounded-lg border border-border bg-muted/40 px-3 py-2.5">
      <div class="flex items-center gap-2">
        <span
          aria-hidden="true"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-foreground text-base font-bold text-background"
        >AI</span>
        <div class="flex flex-col leading-tight">
          <a href="/about/" class="text-sm font-semibold text-foreground underline-offset-2 hover:text-accent hover:underline">{author}</a>
          <span class="text-[11px] text-foreground-muted">編集部 + AIエージェント群 · <a href="/about/" class="underline underline-offset-2 hover:text-accent">運営者情報</a></span>
        </div>
      </div>
      <span aria-hidden="true" class="text-foreground-muted/40">|</span>
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span aria-hidden="true" class="text-foreground-muted/40">|</span>
      <span class="inline-flex items-center gap-1 text-xs text-foreground-muted">
        <svg aria-hidden="true" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><polyline points="12 7 12 12 15 14"></polyline></svg>
        約{readMinutes}分で読了
      </span>
      <span
        aria-hidden="true"
        class:list={[
          "text-foreground-muted/40 max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    {
      hasAffiliate && (
        <p class="mt-2 text-xs leading-5 text-foreground-muted">
          本記事にはアフィリエイトリンクを含みます。紹介料を受領する場合がありますが、レビュー・比較の内容は独自の検証に基づいており、評価には影響しません（<a href="/pr-disclosure/" class="underline underline-offset-2">広告・PR表示</a>）。
        </p>
      )
    }
    {
      review && (
        <p class="mt-2 inline-flex items-center gap-2 border border-border bg-muted/40 px-3 py-1.5 text-xs text-foreground">
          <span class="font-bold">編集部評価</span>
          <span class="font-mono font-semibold tabular-nums text-accent">{review.rating.toFixed(1)} / 5.0</span>
          <span class="text-foreground-muted">（{review.itemName}・実運用ベース）</span>
        </p>
      )
    }
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>

    {
      reviewJsonLd && (
        <script type="application/ld+json" is:inline set:html={JSON.stringify(reviewJsonLd)} />
      )
    }

    <!-- 記事末尾アフィリCTA（frontmatter affiliateCta 駆動・PR表示つき） -->
    {
      affiliateCta?.map(cta => (
        <AffiliateCta
          toolId={cta.id}
          lead={cta.lead}
          note={cta.note}
          experienced={cta.experienced}
        />
      ))
    }

    <!-- 著者・検証体制ボックス（E-E-A-T） -->
    <aside class="mt-10 flex gap-4 rounded-xl border border-border bg-muted/40 p-5" data-pagefind-ignore>
      <span
        aria-hidden="true"
        class="inline-flex h-12 w-12 flex-none items-center justify-center rounded-full bg-foreground text-lg font-bold text-background"
      >AI</span>
      <div class="text-sm leading-6">
        <p class="font-bold text-foreground">{author} 編集部</p>
        <p class="mt-1 text-foreground-muted">
          Claude Code で「AI会社」を運営する個人開発者＋AIエージェント群による編集体制。紹介するツールは記事量産・サイト運営の<strong>実運用で使った体験</strong>をもとに、公式情報と突き合わせて執筆しています。うまくいかなかったことも隠さず書くのが方針です。
        </p>
        <p class="mt-2">
          <a href="/about/" class="font-medium text-accent underline underline-offset-2">運営者情報を見る</a>
          <span class="mx-2 text-foreground-muted/40">|</span>
          <a href="/editorial-team/" class="font-medium text-accent underline underline-offset-2">編集体制について</a>
        </p>
      </div>
    </aside>

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <hr class="my-6 border-dashed" />

    {
      relatedPosts.length > 0 && (
        <section data-pagefind-ignore class="mb-8">
          <h2 class="mb-4 text-lg font-bold text-foreground">関連記事</h2>
          <ul class="grid gap-4 sm:grid-cols-3">
            {relatedPosts.map(rp => (
              <li class="rounded-xl border border-border p-4 transition hover:border-accent/60">
                <a href={getPath(rp.id, rp.filePath)} class="block hover:opacity-90">
                  <p class="text-sm font-semibold leading-6 text-accent">{rp.data.title}</p>
                  <p class="mt-2 line-clamp-3 text-xs leading-5 text-foreground-muted">{rp.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>前の記事</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>次の記事</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>

  <!-- スマホ追従CTA（アフィリ記事のみ。ファーストビュー通過後に表示） -->
  {
    hasAffiliate && primaryTool && (
      <div
        id="sticky-cta"
        data-pagefind-ignore
        class="pointer-events-none fixed inset-x-0 bottom-0 z-40 translate-y-full p-2 transition-transform duration-300 md:hidden"
      >
        <div class="pointer-events-auto mx-auto flex max-w-md items-center gap-2 rounded-2xl border border-border bg-card-bg/95 p-2 shadow-lg backdrop-blur">
          <button
            id="sticky-cta-close"
            type="button"
            aria-label="閉じる"
            class="flex h-8 w-8 flex-none items-center justify-center rounded-full text-foreground-muted hover:bg-muted"
          >✕</button>
          <div class="min-w-0 flex-none pr-1">
            <p class="truncate text-xs font-bold text-foreground">{primaryTool.name}</p>
            <p class="text-[10px] text-foreground-muted">{ctaSub}</p>
          </div>
          <a
            href={`/go/${primaryTool.id}`}
            rel="sponsored nofollow"
            class="flex-1 rounded-full bg-accent py-3 text-center text-sm font-bold text-accent-fg transition hover:bg-foreground hover:text-background"
          >{ctaLabel}</a>
        </div>
      </div>
    )
  }

  <Footer />
</Layout>

<script is:inline data-astro-rerun>
  (function () {
    var bar = document.getElementById("sticky-cta");
    if (!bar) return;
    if (sessionStorage.getItem("stickyCtaClosed") === "1") return;
    var closeBtn = document.getElementById("sticky-cta-close");
    var shown = false;
    function onScroll() {
      var pass = window.scrollY > window.innerHeight;
      if (pass && !shown) {
        bar.classList.remove("translate-y-full");
        shown = true;
      } else if (!pass && shown) {
        bar.classList.add("translate-y-full");
        shown = false;
      }
    }
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
    if (closeBtn) {
      closeBtn.addEventListener("click", function () {
        bar.classList.add("translate-y-full");
        window.removeEventListener("scroll", onScroll);
        sessionStorage.setItem("stickyCtaClosed", "1");
      });
    }
  })();
</script>

<script is:inline data-astro-rerun>
  /** Create a progress indicator
   *  at the top */
  function createProgressBar() {
    // Create the main container div
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    // Create the progress bar div
    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    // Append the progress bar to the progress container
    progressContainer.appendChild(progressBar);

    // Append the progress container to the document body or any other desired parent element
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar
   *  when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks in the document,
   * allowing users to copy code easily. */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      // Check if --file-name-offset custom property exists
      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      // Determine the top positioning class
      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      // wrap codebock with relative parent element
      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      // visual feedback that task is completed
      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
