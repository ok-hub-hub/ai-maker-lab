---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { PUBLIC_GOOGLE_SITE_VERIFICATION } from "astro:env/client";
import { SITE } from "@/config";
import "@/styles/global.css";

type Props = {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  pubDatetime?: Date;
  modDatetime?: Date | null;
  scrollSmooth?: boolean;
};

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDatetime,
  modDatetime,
  scrollSmooth = false,
} = Astro.props;

const socialImageURL = new URL(ogImage, Astro.url);

// 記事ページ（pubDatetime あり）は BlogPosting、それ以外は WebSite + Organization。
// 旧実装は全ページ BlogPosting 固定で、非記事ページに datePublished:"undefined" が出力されていた。
const structuredData = pubDatetime
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: `${title}`,
      image: `${socialImageURL}`,
      datePublished: pubDatetime.toISOString(),
      ...(modDatetime && { dateModified: modDatetime.toISOString() }),
      author: [
        {
          "@type": "Person",
          name: `${author}`,
          ...(profile && { url: profile }),
        },
      ],
      publisher: {
        "@type": "Organization",
        name: SITE.title,
        url: SITE.website,
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: SITE.title,
      url: SITE.website,
      description: SITE.desc,
      publisher: {
        "@type": "Organization",
        name: SITE.title,
        url: SITE.website,
      },
    };
---

<!doctype html>
<html
  dir={SITE.dir}
  lang=`${SITE.lang ?? "en"}`
  class={`${scrollSmooth && "scroll-smooth"}`}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <!-- Load Fonts -->
    <Font
      cssVariable="--font-inter"
      preload={[{ subset: "latin", weight: 400, style: "normal" }]}
    />
    <Font cssVariable="--font-noto-sans-jp" />
    <Font cssVariable="--font-noto-serif-jp" />
    <Font cssVariable="--font-google-sans-code" />

    <!-- General Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Article Published/Modified time -->
    {
      pubDatetime && (
        <meta
          property="article:published_time"
          content={pubDatetime.toISOString()}
        />
      )
    }
    {
      modDatetime && (
        <meta
          property="article:modified_time"
          content={modDatetime.toISOString()}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Google JSON-LD Structured data -->
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />

    <!-- Enable RSS feed auto-discovery  -->
    <!-- https://docs.astro.build/en/recipes/rss/#enabling-rss-feed-auto-discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE.title}
      href={new URL("rss.xml", Astro.site)}
    />

    <meta name="theme-color" content="" />

    <!-- Google Search Console site verification -->
    <meta
      name="google-site-verification"
      content={PUBLIC_GOOGLE_SITE_VERIFICATION || "YPBaLL64xAQsaj0LvmgfVuNy8_HC6CTbxb8nsgbmkKo"}
    />

    <!-- Google Analytics 4 (production only) -->
    {
      import.meta.env.PROD && (
        <>
          <script
            is:inline
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-S55TTRMBX0"
          />
          <script is:inline set:html={`
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-S55TTRMBX0', { anonymize_ip: true });
          `} />
        </>
      )
    }

    <ClientRouter />

    <!-- Minimal inline script to prevent FOUC - sets theme immediately -->
    <script is:inline>
      (function () {
        const initialColorScheme = ""; // "light" | "dark"
        const currentTheme = localStorage.getItem("theme");

        function getPreferTheme() {
          if (currentTheme) return currentTheme;
          if (initialColorScheme) return initialColorScheme;
          return window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }

        const themeValue = getPreferTheme();

        // Set theme immediately to prevent flash
        document.firstElementChild?.setAttribute("data-theme", themeValue);

        // Export minimal API for external script
        window.theme = {
          themeValue: themeValue,
          getTheme: () => window.theme.themeValue,
          setTheme: val => {
            window.theme.themeValue = val;
          },
        };
      })();
    </script>
    <!-- A8.net リンクマネージャー：公式URLを自動でA8アフィリリンクに置換 -->
    <script is:inline src="//statics.a8.net/a8link/a8linkmgr.js"></script>
    <script is:inline>
      a8linkmgr({
        "config_id": "AwCpjYs4q25StXZqogep"
      });
    </script>
    <!-- アフィリエイトリンク click を GA4 イベントとして計測 -->
    <script is:inline>
      document.addEventListener("click", function (e) {
        const a = e.target.closest && e.target.closest("a[href]");
        if (!a || !a.href) return;
        if (typeof gtag !== "function") return;
        // 内部 /go/ クローク（主要なアフィリ導線）
        const isCloaked = a.pathname && a.pathname.indexOf("/go/") === 0;
        // 外部スポンサー/nofollow リンク（生のアフィリリンク）
        const isExternalSponsored =
          a.rel && /sponsored|nofollow/.test(a.rel) &&
          a.hostname && a.hostname !== location.hostname;
        if (!isCloaked && !isExternalSponsored) return;
        gtag("event", "affiliate_click", {
          event_category: "outbound",
          event_label: a.href,
          transport_type: "beacon",
          link_domain: isCloaked ? location.hostname : a.hostname,
          link_slug: isCloaked
            ? a.pathname.replace("/go/", "").replace(/\/$/, "")
            : "",
          link_text: (a.textContent || "").trim().slice(0, 80),
          page_path: location.pathname,
        });
      }, { passive: true, capture: true });
    </script>

    <!-- Microsoft Clarity -->
    <script type="text/javascript" is:inline>
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wtgzgss0n2");
    </script>
  </head>
  <body>
    <slot />

    <!-- Load full theme logic -->
    <script src="../scripts/theme.ts"></script>
  </body>
</html>
